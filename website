<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RAZE Non-Alcoholic Beer</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, Helvetica, sans-serif;
    }

    body {
      background: #f7f1e8;
      color: #1c1c1c;
    }

    header {
      background: #ffffff;
      padding: 20px 8%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #ddd;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .logo {
      font-size: 30px;
      font-weight: 900;
      letter-spacing: 8px;
      color: #8a3b08;
    }

    nav a {
      margin-left: 25px;
      text-decoration: none;
      color: #222;
      font-weight: bold;
      font-size: 14px;
    }

    nav a:hover {
      color: #8a3b08;
    }

    .hero {
      min-height: 85vh;
      padding: 70px 8%;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: 50px;
      background: linear-gradient(120deg, #fffaf2, #ead0aa);
    }

    .hero-text h1 {
      font-size: 72px;
      line-height: 0.95;
      color: #111;
      text-transform: uppercase;
    }

    .hero-text span {
      color: #8a3b08;
    }

    .hero-text p {
      margin: 25px 0;
      font-size: 20px;
      line-height: 1.5;
      max-width: 520px;
    }

    .button {
      display: inline-block;
      padding: 15px 30px;
      background: #8a3b08;
      color: white;
      text-decoration: none:
      font-weight: bold;
      border-radius: 4px;
      letter-spacing: 1px;
    }

    .button:hover {
      background: #5c2605;
    }

    .can-box {
      height: 520px;
      max-width: 290px;
      margin: auto;
      background: linear-gradient(90deg, #fdfdfd, #ffffff, #eee1d0);
      border-radius: 35px;
      box-shadow: 0 25px 60px rgba(0,0,0,0.25);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      border-top: 18px solid #7b3307;
      border-bottom: 18px solid #7b3307;
      position: relative;
    }

    .can-box h2 {
      font-size: 42px;
      color: #8a3b08;
      letter-spacing: 6px;
    }

    .can-box p {
      margin-top: 15px;
      text-align: center;
      font-weight: bold;
      letter-spacing: 2px;
    }

    .beer-glass {
      width: 150px;
      height: 250px;
      margin: auto;
      border: 5px solid rgba(255,255,255,0.9);
      border-radius: 18px 18px 35px 35px;
      background: linear-gradient(180deg, #f6d08b 0%, #b65a08 40%, #5f2604 100%);
      box-shadow: inset 0 0 25px rgba(255,255,255,0.35), 0 20px 45px rgba(0,0,0,0.25);
      position: relative;
    }

    .beer-glass::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 42px;
      background: #fff1cc;
      border-radius: 12px 12px 8px 8px;
    }

    .section {
      padding: 70px 8%;
    }

    .section h2 {
      font-size: 42px;
      margin-bottom: 35px;
      text-align: center;
      text-transform: uppercase;
    }

    .products {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
    }

    .product-card {
      background: white;
      padding: 30px;
      border-radius: 18px;
      text-align: center;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .mini-can {
      width: 110px;
      height: 210px;
      background: linear-gradient(90deg, #ffffff, #f8f2e8, #ffffff);
      border-radius: 22px;
      border-top: 10px solid #7b3307;
      border-bottom: 10px solid #7b3307;
      margin: 0 auto 25px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #8a3b08;
      font-weight: 900;
      letter-spacing: 3px;
      box-shadow: 0 12px 25px rgba(0,0,0,0.18);
    }

    .product-card h3 {
      font-size: 24px;
      margin-bottom: 10px;
    }

    .product-card p {
      color: #555;
      margin-bottom: 15px;
      line-height: 1.4;
    }

    .price {
      font-size: 22px;
      font-weight: bold;
      color: #8a3b08;
      margin-bottom: 20px;
    }

    .product-card button {
      border: none;
      padding: 13px 25px;
      background: #111;
      color: white;
      font-weight: bold;
      border-radius: 4px;
      cursor: pointer;
    }

    .product-card button:hover {
      background: #8a3b08;
    }

    .about {
      background: #111;
      color: white;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 50px;
      align-items: center;
    }

    .about h2 {
      text-align: left;
      color: #f1b37d;
    }

    .about p {
      font-size: 18px;
      line-height: 1.7;
    }

    .features {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-top: 35px;
    }

    .feature {
      background: #222;
      padding: 22px;
      border-radius: 12px;
      border-left: 4px solid #8a3b08;
    }

    .cart {
      background: #fff;
      padding: 50px 8%;
      text-align: center;
    }

    #cart-items {
      margin: 20px auto;
      max-width: 500px;
      text-align: left;
      line-height: 1.8;
    }

    footer {
      background: #8a3b08;
      color: white;
      text-align: center;
      padding: 25px;
      font-weight: bold;
      letter-spacing: 1px;
    }

    @media (max-width: 850px) {
      .hero,
      .about,
      .products,
      .features {
        grid-template-columns: 1fr;
      }

      .hero-text h1 {
        font-size: 48px;
      }

      nav {
        display: none;
      }
    }
  </style>
</head>
<body>
  <header>
    <div class="logo">RAZE</div>
    <nav>
      <a href="#shop">Shop</a>
      <a href="#about">About</a>
      <a href="#cart">Cart</a>
    </nav>
  </header>

  <section class="hero">
    <div class="hero-text">
      <h1>Raze <span>Your Game</span></h1>
      <p>A deep amber non-alcoholic beer made for athletes who want the taste of real beer without the alcohol. Full flavour. Zero alcohol. No compromise.</p>
      <a href="#shop" class="button">Shop Now</a>
    </div>

    <div class="can-box">
      <h2>RAZE</h2>
      <p>DEEP AMBER<br>NON-ALCOHOLIC BEER<br><br>0.0% ALC</p>
    </div>
  </section>

  <section class="section" id="shop">
    <h2>Shop Raze</h2>
    <div class="products">
      <div class="product-card">
        <div class="mini-can">RAZE</div>
        <h3>Deep Amber Can</h3>
        <p>A smooth, malty, deep amber non-alcoholic beer with a crisp finish.</p>
        <div class="price">$3.49</div>
        <button onclick="addToCart('Deep Amber Can', 3.49)">Add to Cart</button>
      </div>

      <div class="product-card">
        <div class="mini-can">RAZE</div>
        <h3>Deep Amber 6-Pack</h3>
        <p>Perfect for post-game recovery, team events, or weekend plans.</p>
        <div class="price">$17.99</div>
        <button onclick="addToCart('Deep Amber 6-Pack', 17.99)">Add to Cart</button>
      </div>

      <div class="product-card">
        <div class="mini-can">RAZE</div>
        <h3>Deep Amber 24-Pack</h3>
        <p>Stock up with a full case of Raze deep amber non-alcoholic beer.</p>
        <div class="price">$59.99</div>
        <button onclick="addToCart('Deep Amber 24-Pack', 59.99)">Add to Cart</button>
      </div>
    </div>
  </section>

  <section class="section about" id="about">
    <div>
      <h2>Deep Amber Beer. Athlete Mindset.</h2>
      <p>Raze is built for people who train hard but still want a proper beer experience. It is not a sports drink. It is a bold, refreshing deep amber non-alcoholic beer made for recovery moments, post-game celebrations, and active lifestyles.</p>
    </div>

    <div class="beer-glass"></div>

    <div class="features">
      <div class="feature">
        <h3>0.0% Alcohol</h3>
        <p>Enjoy the beer taste without alcohol slowing you down.</p>
      </div>
      <div class="feature">
        <h3>Deep Amber Taste</h3>
        <p>Malty, smooth, and richer than a light lager.</p>
      </div>
      <div class="feature">
        <h3>Post-Game Ready</h3>
        <p>Designed for athletes, teams, and active people.</p>
      </div>
    </div>
  </section>

  <section class="cart" id="cart">
    <h2>Your Cart</h2>
    <div id="cart-items">Your cart is empty.</div>
    <h3 id="total">Total: $0.00</h3>
  </section>

  <footer>
    RAZE NON-ALCOHOLIC BEER | DEEP AMBER | RAZE YOUR GAME
  </footer>

  <script>
    let cart = [];

    function addToCart(product, price) {
      cart.push({ product, price });
      updateCart();
    }

    function updateCart() {
      const cartItems = document.getElementById('cart-items');
      const totalText = document.getElementById('total');

      if (cart.length === 0) {
        cartItems.innerHTML = 'Your cart is empty.';
        totalText.innerHTML = 'Total: $0.00';
        return;
      }

      let total = 0;
      cartItems.innerHTML = '';

      cart.forEach((item) => {
        total += item.price;
        cartItems.innerHTML += `<p>${item.product} - $${item.price.toFixed(2)}</p>`;
      });

      totalText.innerHTML = `Total: $${total.toFixed(2)}`;
    }
  </script>
</body>
</html>
